        <!-- STYLES -->
        
        <Style x:Key="Transparent" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Loader" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontFamily" Value="{DynamicResource Poppins Regular}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{TemplateBinding Tag}" Stretch="Uniform" Fill="White" Width="16" Height="16" Margin="12,0,10,0"/>
                                <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <StackPanel>
                            <Grid x:Name="MainContent" Background="#313131" Height="35" Margin="0,1,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path x:Name="Icon" Margin="5" Fill="#828282" Stretch="Uniform" Width="16" Height="16" Data="{Binding IconData}"/>
                                    <TextBlock x:Name="HeaderText" Text="{Binding Header}" VerticalAlignment="Center" Margin="3" Foreground="#bebebe" FontSize="15" FontFamily="{DynamicResource Poppins Regular}"/>
                                </StackPanel>
                            </Grid>
                            <ItemsControl x:Name="SubItems" ItemsSource="{Binding SubItems}" Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Margin="0,1,0,0" Height="30">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Margin="5" Fill="#4d7eae" Stretch="Uniform" Width="16" Height="16" Data="{StaticResource Document}"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="3" Foreground="#949494" FontSize="15" FontFamily="{DynamicResource Poppins Regular}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainContent" Property="Background" Value="#313131"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="MainContent" Property="Background" Value="#3f3f3f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Misc" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#2d2d2d"/>
