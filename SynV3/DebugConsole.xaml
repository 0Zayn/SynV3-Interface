<Window x:Class="SynV3.DebugConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SynV3"
        mc:Ignorable="d"
        Title="DebugConsole" Height="450" Width="800" WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterScreen">
    <Border Background="#191919" CornerRadius="8">
        <Grid>
            <Border x:Name="Titlebar" Background="#101010" MouseLeftButtonDown="Titlebar_MLBD" CornerRadius="8,8,0,0" VerticalAlignment="Top" Height="40">
                <Grid>
                    <TextBlock Text="Synapse Debug Console" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="LightGray" FontSize="15" FontFamily="{DynamicResource Poppins Regular}"/>

                    <Button x:Name="MinimizeT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,75,0" Height="30" Width="30" Style="{DynamicResource Transparent}">
                        <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Minimize}"/>
                    </Button>

                    <Button x:Name="MaximizeT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,40,0" Height="30" Width="30" Style="{DynamicResource Transparent}">
                        <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Maximize}"/>
                    </Button>

                    <Button x:Name="CloseT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Height="30" Width="30" Style="{DynamicResource Transparent}" Margin="0,5,5,0">
                        <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Close}"/>
                    </Button>
                </Grid>
            </Border>

            <Border Background="#191919" Margin="0,85,0,0" CornerRadius="0,0,8,8">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="Console"/>
                </ScrollViewer>
            </Border>

            <Border Background="#1a1a1a" Height="45" VerticalAlignment="Top" Margin="0,40,0,0">
                <Border.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Border.Effect>

                <StackPanel Orientation="Horizontal">
                    <Button Style="{DynamicResource Transparent}" Width="45">
                        <Path Data="{DynamicResource Clipboard}" Stroke="#767575" StrokeThickness="2" Stretch="Uniform" Width="16"/>
                    </Button>

                    <Button Style="{DynamicResource Transparent}" Width="45">
                        <Path Data="{DynamicResource Eraser}" Fill="#767575" Stroke="#767575" StrokeThickness="1" Stretch="Uniform" Width="18"/>
                    </Button>

                    <TextBox Style="{DynamicResource Debug}" Height="35" Width="665"/>

                    <Button Style="{DynamicResource Transparent}" Width="45">
                        <Path Data="{DynamicResource Out}" Fill="#767575" Stretch="Uniform" Width="18"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
