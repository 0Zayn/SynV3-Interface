    <Window.Resources>
        <Style x:Key="TabControl" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <ScrollViewer x:Name="ScrollViewer" MaxWidth="696" HorizontalAlignment="Left" Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl>
                                        <TabPanel x:Name="HeaderPanel" Panel.ZIndex="1" IsItemsHost="True"/>
                                    </ItemsControl>
                                    <Button Style="{DynamicResource Transparent}" Width="25" Height="25" Margin="3,2,2,2" Click="AddTab_Click">
                                        <Path Height="12" StrokeLineJoin="Round" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Stroke="#8f8f8f" StrokeThickness="1.5" Data="M6 1V11M11 6H1" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="1" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                                <Grid x:Name="ContentPanel" KeyboardNavigation.TabIndex="2" KeyboardNavigation.TabNavigation="Local" KeyboardNavigation.DirectionalNavigation="Contained">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                        <ContentPresenter Content="{TemplateBinding SelectedContent}" ContentTemplate="{TemplateBinding SelectedContentTemplate}" ContentStringFormat="{TemplateBinding SelectedContentStringFormat}" ContentSource="SelectedContent" x:Name="PART_SelectedContentHost" Margin="2" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Tab" TargetType="TabItem">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Foreground" Value="#8f8f8f"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{DynamicResource Poppins Regular}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="TabBackground" Margin="0,0,5,0" Background="#212120" BorderThickness="1" CornerRadius="6">
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource ContextMenu}">
                                        <MenuItem Header="Duplicate" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Clipboard}" />
                                        <MenuItem Header="Execute" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Cogs}" />
                                        <MenuItem Header="Format" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Format}" />
                                        <MenuItem Header="Customize" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Pen}">
                                            <MenuItem Header="Rename" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Rename}" />
                                            <MenuItem Header="Toggle pin" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Pin}" />
                                            <MenuItem Header="Toggle readonly" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Lock}" />
                                            <MenuItem Header="Set icon" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Set}" />
                                        </MenuItem>
                                        <MenuItem Header="Set directory" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Folder}" />
                                        <MenuItem Header="Reset targets" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Bolt}" />
                                        <MenuItem Header="Toggle auto-execute" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Settings}" />
                                        <MenuItem Header="Close all but this" Style="{DynamicResource DarkMenu}" Tag="{DynamicResource Close}" />
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Path Data="{DynamicResource TabIcon}" Height="12" Width="12" Stretch="Uniform" Fill="#8f8f8f" Margin="12,0,0,0" VerticalAlignment="Center"/>

                                    <ContentPresenter x:Name="ContentSite" Margin="12,0,0,0" Grid.Column="1" VerticalAlignment="Center" ContentSource="Header"/>

                                    <Button Click="CloseTab_Click" Grid.Column="2" Background="Transparent" BorderThickness="0" Margin="30,0,10,0" Style="{DynamicResource Transparent}">
                                        <Path Data="{DynamicResource Close}" Height="10" Width="10" Stretch="Uniform" Fill="#8f8f8f"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabBackground" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TabBackground" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#161616" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.EnterActions>
                                <MultiTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TabBackground" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#212120" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiTrigger.ExitActions>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="TabBackground" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#2d2d2d" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="TabBackground" Property="Background" Value="#212120"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
</Window>
