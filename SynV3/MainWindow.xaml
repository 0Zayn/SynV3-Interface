<Window x:Class="SynV3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SynV3"
        mc:Ignorable="d"
        Title="MainWindow" MinHeight="450" MinWidth="950" Height="450" Width="950" WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterScreen">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Border x:Name="Window" MouseLeftButtonDown="Titlebar_MLBD" CornerRadius="8" Background="#1b1b1a" BorderBrush="#343434" BorderThickness="1">
            <Grid>
                <Border Background="#212120" CornerRadius="8,8,0,0" VerticalAlignment="Top" Height="50">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Margin="6" VerticalAlignment="Top" HorizontalAlignment="Left">
                            <Image Source="Resources/Images/SynapseLogo.png" RenderOptions.BitmapScalingMode="HighQuality" Stretch="Uniform" Width="120" Height="30"/>
                            <TextBlock Foreground="#f6f6f5" FontFamily="{DynamicResource Poppins Medium}" Margin="8,0,0,0" FontSize="12"><Run Text="UI 1.0.0 beta-14a"/><LineBreak/><Run Text="N/A"/></TextBlock>
                        </StackPanel>

                        <Grid x:Name="Navigation" Height="30" Margin="10" Width="Auto" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="EditorN" Checked="NavigationHandler" Content="{DynamicResource Editor}" Foreground="#c0cbca" Width="17" Style="{DynamicResource NavigationF}" IsChecked="True">
                                    <RadioButton.ToolTip>
                                        <ToolTip Style="{DynamicResource Dark}" Tag="{DynamicResource Editor}" Content="Editor"/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton x:Name="SettingsN" Checked="NavigationHandler" Content="{DynamicResource Settings}" Margin="12,0,0,0" Foreground="#c0cbca" Width="18" Style="{DynamicResource NavigationO}">
                                    <RadioButton.ToolTip>
                                        <ToolTip Style="{DynamicResource Dark}" Tag="{DynamicResource Settings}" Content="Settings"/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton x:Name="ThemesN" Checked="NavigationHandler" Content="{DynamicResource Themes}" Margin="12,0,0,0" Foreground="#c0cbca" Width="18" Style="{DynamicResource NavigationO}">
                                    <RadioButton.ToolTip>
                                        <ToolTip Style="{DynamicResource Dark}" Tag="{DynamicResource Themes}" Content="Themes"/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton x:Name="PluginsN" Checked="NavigationHandler" Content="{DynamicResource Plugins}" Margin="12,0,0,0" Foreground="#565638" Width="18" Style="{DynamicResource NavigationO}">
                                    <RadioButton.ToolTip>
                                        <ToolTip Style="{DynamicResource Dark}" Tag="{DynamicResource Plugins}" Content="Packages"/>
                                    </RadioButton.ToolTip>
                                </RadioButton>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="Website" VerticalAlignment="Top" HorizontalAlignment="Right" Height="30" Width="30" Style="{DynamicResource Transparent}" Margin="0,5,116,0">
                            <Path Height="14" Width="14" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Globe}"/>
                        </Button>

                        <Button x:Name="Support" VerticalAlignment="Top" HorizontalAlignment="Right" Height="30" Width="30" Style="{DynamicResource Transparent}" Margin="0,5,151,0">
                            <Path Height="14" Width="14" Fill="#efff21" Stretch="Uniform" Data="{DynamicResource Smile}"/>
                        </Button>

                        <Button x:Name="MinimizeT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,75,0" Height="30" Width="30" Style="{DynamicResource Transparent}">
                            <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Minimize}"/>
                        </Button>

                        <Button x:Name="MaximizeT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,5,40,0" Height="30" Width="30" Style="{DynamicResource Transparent}">
                            <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Maximize}"/>
                        </Button>

                        <Button x:Name="CloseT" Click="WindowControl" VerticalAlignment="Top" HorizontalAlignment="Right" Height="30" Width="30" Style="{DynamicResource Transparent}" Margin="0,5,5,0">
                            <Path Height="12" Width="12" Fill="#fbfbfb" Stretch="Uniform" Data="{DynamicResource Close}"/>
                        </Button>
                    </Grid>
                </Border>

                <Border x:Name="Homepage" Margin="0,50,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="AiSpace" Width="0"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AiPanel" Panel.ZIndex="1" BorderThickness="0,0,1,0" BorderBrush="#202020" Background="#1c1c1c" Grid.Column="0" Width="200" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="45"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#1c1c1b" BorderThickness="0,0,0,1" BorderBrush="#202020">
                                    <StackPanel Orientation="Vertical">
                                        <Border Background="#c2410c">
                                            <TextBlock Text="An OpenAI key is necessary to use SynapseAI" FontFamily="{DynamicResource Poppins Regular}" Cursor="Hand" TextDecorations="Underline" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center" Foreground="#dcdcdc" Margin="8" FontSize="12"/>
                                        </Border>
                                        
                                        <Border CornerRadius="8" Margin="5" BorderThickness="1" BorderBrush="#252525">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{DynamicResource Bot}" Fill="#cbcbcb" Stretch="Uniform" Width="12" Margin="10"/>
                                                    <TextBlock Text="Chat with SynapseAI" FontFamily="{DynamicResource Poppins Regular}" TextWrapping="Wrap" Foreground="#dcdcdc" Margin="5" FontSize="16" Width="89"/>

                                                    <Border Width="1.2" Background="#202020"/>
                                                    
                                                    <TextBlock Text="Chat" FontFamily="{DynamicResource Poppins Regular}" VerticalAlignment="Center" Foreground="#dcdcdc" Margin="8,0,0,0" FontSize="16"/>
                                                </StackPanel>

                                                <Border Height="1.2" Background="#202020"/>

                                                <TextBlock Text="Talk with SynapseAI to get assistance with your script." FontFamily="{DynamicResource Poppins Regular}" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="#dcdcdc" Margin="8" FontSize="15"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="1" Background="Black" CornerRadius="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{DynamicResource Transparent}" Margin="3,0,0,0" Width="24" Height="24">
                                            <Path Data="{DynamicResource Cogs}" Fill="#cbcbcb" Stretch="Uniform" Width="12"/>
                                        </Button>

                                        <TextBox Width="165" Text="Send message." Style="{DynamicResource AIBox}" Height="32"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Background="#212120" Height="35" VerticalAlignment="Top" Grid.Column="1">
                            <Grid>
                                <TabControl x:Name="TabContainer" Style="{DynamicResource TabControl}" Margin="2,0,200,0" Height="Auto" VerticalAlignment="Bottom"/>
                                <TextBox Height="35" Width="190" Margin="5,0,5,0" VerticalAlignment="Bottom" HorizontalAlignment="Right" Style="{DynamicResource Search}"/>
                            </Grid>
                        </Border>

                        <Border Margin="0,35,200,0" CornerRadius="0,0,0,8" Background="#1c1c1c" Grid.Column="1">
                            <Grid>
                                
                                
                                <StackPanel x:Name="E_Control" Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" Orientation="Horizontal">
                                    <Button Content="Execute" Tag="{DynamicResource Execute}" Style="{DynamicResource Misc}" Width="100" Height="35"/>
                                    <Button Content="Clear" Tag="{DynamicResource Clear}" Style="{DynamicResource Misc}" Margin="4,0,0,0" Width="100" Height="35"/>
                                    <Button Content="Open" Tag="{DynamicResource Open}" Style="{DynamicResource Misc}" Margin="4,0,0,0" Width="100" Height="35"/>
                                    <Button Content="Execute" Tag="{DynamicResource E_File}" Style="{DynamicResource Misc}" Margin="4,0,0,0" Width="100" Height="35"/>
                                    <Button Content="Save" Tag="{DynamicResource Save}" Style="{DynamicResource Misc}" Margin="4,0,0,0" Width="100" Height="35"/>
                                </StackPanel>

                                <StackPanel x:Name="M_Control" Margin="8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal">
                                    <Button Style="{DynamicResource Transparent}" Width="30" Height="30">
                                        <Path Data="{DynamicResource Connect}" Fill="#26543e" Stretch="Uniform" Width="20"/>
                                    </Button>

                                    <Button Style="{DynamicResource Transparent}" Margin="4,0,0,0" Width="30" Height="30">
                                        <Path Data="{DynamicResource Graph}" Stroke="#767575" StrokeThickness="2" Stretch="Uniform" Width="20"/>
                                    </Button>

                                    <Button Style="{DynamicResource Transparent}" Margin="4,0,0,0" Width="30" Height="30">
                                        <Path Data="{DynamicResource Magnifying}" Fill="#767575" Stretch="Uniform" Width="20"/>
                                    </Button>

                                    <Button Style="{DynamicResource Transparent}" Margin="4,0,0,0" Width="30" Height="30" Click="AI_Click">
                                        <Path Data="{DynamicResource Bot}" Fill="#767575" Stretch="Uniform" Width="18"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Background="#20201f" CornerRadius="0,0,8,0" HorizontalAlignment="Right" Width="200" Margin="0,35,0,0" Grid.Column="1">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <ListBox Background="Transparent" BorderThickness="0" ItemsSource="{Binding CollapsibleItems}" ItemContainerStyle="{StaticResource ListBoxItem}" PreviewMouseDown="ListBox_PMD">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <ContentPresenter Content="{Binding}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="Settings" Margin="-1017,50,1017,0">
                    <Grid>
                        <Border Background="#212120" CornerRadius="0,0,0,8" Width="65" HorizontalAlignment="Left">
                            <StackPanel Orientation="Vertical">
                                <RadioButton IsChecked="True" Content="{DynamicResource App}" Height="40" Margin="5" Style="{DynamicResource Selector}"/>
                                <RadioButton Content="{DynamicResource Code}" Height="40" Margin="5" Style="{DynamicResource Selector}"/>
                                <RadioButton Content="{DynamicResource Console}" Height="40" Margin="5" Style="{DynamicResource Selector}"/>
                                <RadioButton Content="{DynamicResource Squares}" Height="40" Margin="5" Style="{DynamicResource Selector}"/>
                                <RadioButton Content="{DynamicResource Cogs}" Height="40" Margin="5" Style="{DynamicResource Selector}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#151515" CornerRadius="0,0,8,0" Margin="65,0,0,0">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <StackPanel Orientation="Vertical">
                                    <Border Margin="5" CornerRadius="5" Height="35" Background="#303030">
                                        <Grid>
                                            <Path HorizontalAlignment="Left" Margin="10" Height="15" Width="15" Data="{DynamicResource App}" Fill="#dfdfdf" Stretch="Uniform"/>
                                            <TextBlock Text="Application" FontSize="15" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="35,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Reset all settings" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Pressing this button will reset all settings and close the application." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <Button Content="Reset" Style="{DynamicResource MiscN}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="65" Height="30" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Show changelog" FontSize="13" HorizontalAlignment="Left" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Clicking this will show you the changelog for the latest version." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <Button x:Name="ShowCL" Click="ShowCL_Click" Content="Show" Style="{DynamicResource MiscN}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="65" Height="30" Margin="5"/>
                                    </Grid>

                                    <Border Margin="5" CornerRadius="5" Height="35" Background="#303030">
                                        <Grid>
                                            <Path HorizontalAlignment="Left" Margin="10" Height="15" Width="15" Data="{DynamicResource Code}" Fill="#dfdfdf" Stretch="Uniform"/>
                                            <TextBlock Text="Editor" FontSize="15" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="35,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Actor bar position" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Adjust the vertical location of the actionbar." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <RadioButton Content="{DynamicResource Left}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="5"/>
                                            <RadioButton Content="{DynamicResource Right}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="0,5,5,5"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="AI features" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Enable beta AI features for code editing." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Compact editor buttons" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Reduces the size of the editor buttons." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Compact tabs" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Use compact square tabs instead of round padded ones." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Contextual execution" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Files ran from the UI will assume the workspace of their directory." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Default Tab Content" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="What will be written to the contents of a new tab." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <TextBox Text="print('BUSSSSSSS')" HorizontalAlignment="Right" Margin="0,0,85,0" Width="250" Height="30" Style="{DynamicResource Textbox}"/>
                                        <Button Content="Save" Style="{DynamicResource MiscNS}" Tag="{DynamicResource Save}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="75" Height="30" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Display information area" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Whether the information area below the editor should be shown." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Editor action bar position" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Adjust the vertical position of the editor action bar and tabs." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <RadioButton Content="{DynamicResource Down}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="5"/>
                                            <RadioButton Content="{DynamicResource Up}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="0,5,5,5"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Editor scroll speed" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Adjusts the speed at which the mouse scrolls in the editor." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <Slider Style="{DynamicResource Slider}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="150" Height="30" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Enable sounds" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="When enabled, certain interface elements and notifications will have subtle sounds." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Font Size" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Changes the size of the editor font." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <Slider Style="{DynamicResource Slider}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="150" Height="30" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Format on save" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Automatically format your code when saving to a file." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Hide sidebar" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Toggle the visibility of the sidebar. CTRL+B can also be used." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Ligatures" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Enables whether font ligatures will be rendered." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Lua language server" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Enables the intelligent autocompletion and intellisense engine. Requires start to apply." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Maximum characters to tokenize per line" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Controls the number of characters that is styled per editor line." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <Slider Style="{DynamicResource Slider}" HorizontalAlignment="Right" VerticalAlignment="Center" Width="150" Height="30" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Minimap" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Configure the editor minimap." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <RadioButton Content="{DynamicResource E_No}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="5"/>
                                            <RadioButton Content="{DynamicResource E_Left}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="0,5,5,5"/>
                                            <RadioButton Content="{DynamicResource E_Right}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="0,5,5,5"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Show unsaved warnings" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Warnings will be shown when trying to delete unsaved content." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <CheckBox Style="{DynamicResource Checkbox}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5"/>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Editor action bar position" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Adjust the vertical position of the editor action bar and tabs." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <RadioButton Content="{DynamicResource Left}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="5"/>
                                            <RadioButton Content="{DynamicResource Right}" Style="{DynamicResource RadioSelect}" Width="50" Height="30" Margin="0,5,5,5"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,5,0,0">
                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Smooth Cursor" HorizontalAlignment="Left" FontSize="13" FontFamily="{DynamicResource Poppins Regular}" Foreground="#dfdfdf"/>
                                            <TextBlock Text="Enables smooth movement of the cursor." HorizontalAlignment="Left" FontSize="11" FontFamily="{DynamicResource Poppins Regular}" Margin="0,-1,0,0" Foreground="#707070"/>
                                        </StackPanel>

